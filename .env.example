HVA_LLM_PROVIDER=openai-compatible
HVA_LLM_BASE_URL=https://api.example.com/v1
HVA_LLM_MODEL=your-model-name
HVA_LLM_API_KEY=replace-me
HVA_LLM_SUPPORTS_RESPONSE_FORMAT=true
HVA_CORS_ORIGINS=http://127.0.0.1:8000

# Optional durable fact graph (default: memory)
HVA_FACT_STORE=memory
HVA_NEO4J_URI=neo4j://127.0.0.1:7687
HVA_NEO4J_USER=neo4j
HVA_NEO4J_PASSWORD=replace-me
HVA_NEO4J_DATABASE=neo4j
