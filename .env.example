HVA_LLM_PROVIDER=openai-compatible
HVA_LLM_BASE_URL=https://api.example.com/v1
HVA_LLM_MODEL=your-model-name
HVA_LLM_API_KEY=replace-me
HVA_LLM_SUPPORTS_RESPONSE_FORMAT=true
HVA_LLM_TEMPERATURE=0.75
HVA_LLM_MAX_TOKENS=900
HVA_LLM_TIMEOUT=30
HVA_LLM_MAX_RETRIES=2
HVA_AGENT_RUNTIME=baseline
HVA_LLM_MODS=adversarial_interview
HVA_LLM_FALLBACK=true
HVA_CORS_ORIGINS=http://127.0.0.1:8000
# Required only for trusted /api/debug/* and context-preview access
HVA_DEBUG_TOKEN=replace-with-a-long-random-value

# Optional durable fact graph (default: memory)
HVA_FACT_STORE=memory
HVA_NEO4J_URI=neo4j://127.0.0.1:7687
HVA_NEO4J_USER=neo4j
HVA_NEO4J_PASSWORD=replace-me
HVA_NEO4J_DATABASE=neo4j

# Optional indexed long-term Agent memory (default: process-local inverted index)
HVA_MEMORY_STORE=memory
HVA_MEMORY_SQLITE_PATH=data/memory/hva-memory.sqlite3
